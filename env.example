# AralRiskAI — Environment Variables
# Copy this file to .env and fill in your credentials

# ── Anthropic API (for AI assistant) ──────────────────────────
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Google Earth Engine ────────────────────────────────────────
# Run: earthengine authenticate
# Or use a service account JSON:
GEE_SERVICE_ACCOUNT=your-service-account@project.iam.gserviceaccount.com
GEE_KEY_FILE=gee_credentials.json

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=sqlite:///./aralriskai.db

# ── API Settings ───────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=false

# ── Demo Mode (set to false when GEE + model weights are ready) ─
DEMO_MODE=true
